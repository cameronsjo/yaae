{
  "name": "yaae",
  "version": "0.1.0",
  "description": "Why Author Anywhere Else — an Obsidian plugin",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "wdio run wdio.conf.mts",
    "version": "node scripts/update-versions.mjs"
  },
  "keywords": [
    "obsidian",
    "ai",
    "plugin"
  ],
  "author": "Cameron",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.7",
    "@vitest/coverage-v8": "^4.0.16",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.27.2",
    "mocha": "^11.7.5",
    "obsidian": "^1.7.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.16",
    "wdio-obsidian-reporter": "^2.4.0",
    "wdio-obsidian-service": "^2.4.0"
  },
  "dependencies": {
    "compromise": "^14.14.5",
    "gray-matter": "^4.0.3",
    "zod": "^3.24.0"
  }
}
